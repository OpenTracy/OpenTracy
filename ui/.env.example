# =============================================================================
# PureAI Console - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# These are only used for local development (`npm run dev`).
# In Amplify, env vars are set per app/branch via Terraform.

# Environment: "dev" or "prod" (determines default API URLs)
# Locally this defaults to "dev". In Amplify, set via VITE_ENVIRONMENT.
# VITE_ENVIRONMENT=dev

# API Gateway (JWT-authenticated: profile, deployments, secrets, api-keys, evaluations)
# VITE_API_BASE_URL=https://dev-gateway.lunar-sys.com

# Router (API Key-authenticated: chat/completions, models, providers)
# VITE_ROUTER_URL=https://dev-api.lunar-sys.com

# Stats API (defaults to ROUTER_URL if not set)
# VITE_STATS_URL=https://dev-api.lunar-sys.com

# Router Key (for API deletion functionality)
# VITE_ROUTER_KEY=<your-router-key>

# PostHog Analytics
# VITE_PUBLIC_POSTHOG_KEY=phc_xxx
# VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
