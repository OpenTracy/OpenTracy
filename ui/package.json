{
  "name": "opentracy-ui",
  "description": "OpenTracy - Trace Explorer & Observability Dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "author": "OpenTracy",
  "repository": {
    "type": "git",
    "url": "https://github.com/OpenTracy/opentracy"
  },
  "keywords": [
    "ai",
    "console",
    "deployment",
    "models"
  ],
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
