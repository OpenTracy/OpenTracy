# ============================================================================
# Lunar Router — Environment Variables
# ============================================================================
# Copy this file:  cp .env.example .env
# Then fill in your API keys below.
# ============================================================================

# --- LLM Provider Keys (at least one required for chat/inference) ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# GOOGLE_API_KEY=

# --- ClickHouse (auto-configured by docker-compose) -----------------------
# These are pre-set in docker-compose.yml. Only override for custom setups.
# LUNAR_CH_ENABLED=true
# LUNAR_CH_HOST=localhost
# LUNAR_CH_PORT=9000
# LUNAR_CH_HTTP_PORT=8123
# LUNAR_CH_DATABASE=lunar_router
# LUNAR_CH_USERNAME=default
# LUNAR_CH_PASSWORD=lunar
# LUNAR_CH_BATCH_SIZE=500
# LUNAR_CH_FLUSH_INTERVAL=5s

# --- Weights ---------------------------------------------------------------
# Override default weights location (~/.lunar on macOS)
# LUNAR_DATA_HOME=/path/to/weights
