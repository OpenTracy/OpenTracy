# ============================================================================
# OpenTracy — Environment Variables
# ============================================================================
# Copy this file:  cp .env.example .env
# Then fill in your API keys below.
#
# All variables use the OPENTRACY_ prefix. The legacy LUNAR_ prefix is still
# accepted (with a deprecation warning) for compatibility with older .env files.
# ============================================================================

# --- LLM Provider Keys (at least one required for chat/inference) ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# GOOGLE_API_KEY=

# --- ClickHouse (auto-configured by docker-compose) -----------------------
# These are pre-set in docker-compose.yml. Only override for custom setups.
# OPENTRACY_CH_ENABLED=true
# OPENTRACY_CH_HOST=localhost
# OPENTRACY_CH_PORT=9000
# OPENTRACY_CH_HTTP_PORT=8123
# OPENTRACY_CH_DATABASE=opentracy
# OPENTRACY_CH_USERNAME=default
# OPENTRACY_CH_PASSWORD=opentracy
# OPENTRACY_CH_BATCH_SIZE=500
# OPENTRACY_CH_FLUSH_INTERVAL=5s

# --- Weights ---------------------------------------------------------------
# Override default weights location (~/.opentracy on macOS)
# OPENTRACY_DATA_HOME=/path/to/weights
